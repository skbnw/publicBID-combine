# ローカルではこのファイルを secrets.toml にコピーします。
# Streamlit Community CloudではApp settings > Secretsへ同じ内容を登録します。

# Supabase Dashboard > Connect > Direct connection のURI。
# 可能なら postgres 管理ユーザーではなく、db/schema.sql で作る procurement_reader を使います。
# 実際の値をGitへコミットしないでください。
DATABASE_URL = "postgresql://procurement_reader.PROJECT_REF:PASSWORD@HOST:5432/postgres?sslmode=require"
DB_SCHEMA = "procurement"
